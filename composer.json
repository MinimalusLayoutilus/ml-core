{
    "name": "mnhcc/ml-core",
    "version": "0.9.0",
    "description": "Minimalus Layoutilus — core autoloader, base object model, helpers and config",
    "type": "library",
    "license": "LGPL-2.1-only",
    "authors": [
        {
            "name": "Michael Hegenbarth (carschrotter)",
            "email": "mnh@mn-hegenbarth.de"
        }
    ],
    "require": {
        "php": ">=5.4"
    },
    "autoload": {
        "classmap": [
            "classes/",
            "interfaces/",
            "traits/"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^5.7"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable"
}
